# Model ID
# 支持的模型：deepseek-v4-pro, deepseek-v4-flash
MODEL_ID=deepseek-v4-pro

# API Key (required)
ANTHROPIC_API_KEY=your_api_key_here

# API Base URL
# 使用官方 Anthropic API：https://api.anthropic.com
# 使用第三方兼容接口（如 DeepSeek）：https://api.deepseek.com/anthropic
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
